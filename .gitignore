*.cache                   # HMI build and browser caches
*.db-shm                  # Database shared memory (HMI server)
*.db-wal                  # Database write-ahead log (HMI server)
*.pid                     # Process IDs for running HMI servers
.hmiframework/            # Framework binaries (can be restored via NuGet/TE2000)
.hmipkgs/                 # Downloaded HMI packages
