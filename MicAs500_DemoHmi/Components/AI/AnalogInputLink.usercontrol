<div id="TcHmiTextbox_13" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiTextbox" data-tchmi-height="26" data-tchmi-height-unit="px" data-tchmi-horizontal-scroll="Auto" data-tchmi-left="22" data-tchmi-left-unit="px" data-tchmi-reset-to-last-valid-value="True" data-tchmi-text="%pp%hmi::state::scaledValue%/pp%" data-tchmi-top="68" data-tchmi-top-unit="px" data-tchmi-vertical-scroll="Auto" data-tchmi-width="227" data-tchmi-width-unit="px">
